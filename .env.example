# ── Supabase (Sarvaone only) ──────────────────────────────────────────────────
# Use a **dedicated Supabase project** for this app (US / Sarvaone). Do NOT
# reuse URL or keys from the Mexico marketplace DB — that avoids mixed data and
# accidental writes to production you did not intend.
# Create: https://supabase.com/dashboard → New project → copy URL + anon + service_role.
# MUST be the Project URL (https://xxxxx.supabase.co). Do NOT paste anon/publishable keys here
# (values like sb_publishable_… or eyJ… belong in NEXT_PUBLIC_SUPABASE_ANON_KEY only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Local dev only: include pending (unverified) service listings on home + search. Never enable in production.
# SHOW_PENDING_SERVICES=true   # dev: surface pending rows for service-vertical categories (Beauty, Tutoring, …)

# Auth: OTP session JWT (≥32 random chars in production; keep stable across deploys)
JWT_SECRET=
# Twilio WhatsApp (Mexico login OTP + booking alerts). Local dev may omit if send-otp allows dev flow.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# US login OTP via SMS (+1 numbers). E.164, e.g. +15551234567 (A2P 10DLC registration recommended for production).
TWILIO_SMS_FROM=

# FastAPI backend (optional)
FASTAPI_INTERNAL_URL=https://your-fastapi.example.com
INTERNAL_API_SECRET=

# Stripe (test mode — e.g. Priyanka Consultant sandbox in dashboard.stripe.com)
# Developers → API keys: sk_test_… + pk_test_…
# Developers → Webhooks → endpoint https://sarvaone.com/api/webhooks/stripe → whsec_…
# Local webhook forward: stripe listen --forward-to localhost:3006/api/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Cart tax on subtotal + platform fee (non-service goods). US/NJ MVP default is 0 in code; set e.g. 6.625 for NJ sales tax modeling, or 16 for Mexico-only deploys.
MARKETPLACE_VAT_PERCENT=0
# Cart: set true when Stripe Connect is ready (seller payouts). If unset/false, cart charges the platform account only.
MARKETPLACE_CONNECT_REQUIRED=

# App
# Production: canonical origin, no trailing slash — e.g. https://sarvaone.com
# Local: `npm run dev` uses port 3006 — set NEXT_PUBLIC_APP_URL=http://localhost:3006 so server-side
# fetches (e.g. home search) use the same origin as the browser.
NEXT_PUBLIC_APP_URL=https://sarvaone.com

# Dev-only: after you close every localhost tab, Next.js exits once idle (frees port 3006). To keep dev up until you stop it:
# DEV_DISABLE_BROWSER_AUTOKILL=1
# NEXT_PUBLIC_DEV_DISABLE_BROWSER_AUTOKILL=1
# DEV_BROWSER_IDLE_MS=55000

# Search: embeddings + NL parsing (gpt-4o-mini). Same key for both — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: descriptive User-Agent when resolving NJ city/free-text → county via OpenStreetMap Nominatim
# (recommended in production; see https://operations.osmfoundation.org/policies/nominatim/)
# NOMINATIM_USER_AGENT=YourAppName/1.0 (contact@yourdomain.com)

# SEARCH_PARSE_MODEL=gpt-4o-mini
# USD→MXN when user says dollars without pesos (default 17.5)
# Natural-language search price filters use USD (see lib/search-query-parse.ts). No FX env vars.

# Optional: Sentry error monitoring (set in Vercel Production; leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# Admin UI (/admin) and admin APIs: set a strong pin locally; never commit the real value.
# Approve pending service listings here without using buyer WhatsApp OTP.
ADMIN_PIN=

# Vercel Cron: Bearer for GET /api/cron/reconcile-payments. vercel.json runs once daily
# (Hobby); use a per-minute/hourly schedule only on Pro+ or deploys can fail.
CRON_SECRET=

# Optional: booking reminder emails (Resend). WhatsApp uses Twilio above.
RESEND_API_KEY=
# e.g. Naranjogo <recordatorios@tudominio.com> (verify domain in Resend)
REMINDER_EMAIL_FROM=
