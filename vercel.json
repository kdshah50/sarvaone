{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/send-booking-reminders",
      "schedule": "0 4 * * *"
    }
  ]
}
